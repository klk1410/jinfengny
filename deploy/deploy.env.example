# 复制为 deploy/deploy.env 并填写（UTF-8 保存）

DEPLOY_HOST=root@your.server.ip
SSH_PORT=22
# SSH_IDENTITY=C:\Users\you\.ssh\id_ed25519

REMOTE_JAR_ADMIN=/www/wwwroot/your-admin/admin-backend.jar
REMOTE_JAR_APP=/www/wwwroot/your-app/app-backend.jar

REMOTE_STATIC_ADMIN=/www/wwwroot/dist-admin
REMOTE_STATIC_APP=/www/wwwroot/dist-app

# 上传完成后自动重启（任选一种）
# REMOTE_CMD=systemctl restart your-admin && systemctl restart your-app
# REMOTE_RESTART_SYSTEMD_SERVICES=your-admin,your-app
# REMOTE_RESTART_USE_SUDO=1
