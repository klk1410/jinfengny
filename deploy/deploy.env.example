# 复制为 deploy/deploy.env 并填写（deploy.env 已在 .gitignore，不会提交）

# SSH 目标：user@host 或仅 host（此时 user 用 DEPLOY_USER）
DEPLOY_HOST=root@101.37.241.108
# DEPLOY_USER=root

SSH_PORT=22
# 可选：私钥路径，留空则用默认 ssh-agent / 密码登录
# SSH_IDENTITY=C:\Users\Administrator\.ssh\id_ed25519

# 上传后两个 Spring Boot fat jar 放到哪（父目录需已存在）
REMOTE_JAR_ADMIN=/opt/jinfeng/admin-backend.jar
REMOTE_JAR_APP=/opt/jinfeng/app-backend.jar

# 前端静态：目录内会被覆盖（不会删整站其他文件，只 scp 产物覆盖）
REMOTE_STATIC_ADMIN=/www/wwwroot/jinfeng-admin
REMOTE_STATIC_APP=/www/wwwroot/jinfeng-app

# 可选：上传完成后在服务器执行的命令（一键重启服务），留空则跳过
# REMOTE_CMD=systemctl restart jinfeng-admin && systemctl restart jinfeng-app
